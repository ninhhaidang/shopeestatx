{
  "manifest_version": 3,
  "name": "ShopeeStatX",
  "description": "Thống kê tổng số tiền bạn đã tiêu trên Shopee",
  "version": "3.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://shopee.co.id/*",
    "https://shopee.co.th/*",
    "https://shopee.ph/*",
    "https://shopee.com.my/*",
    "https://shopee.sg/*",
    "https://shopee.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
